# RAG agent config. Copy to .env (gitignored) and fill in from the deployed infra.
#
# LLM_API_KEY / EMBED_API_KEY = the APIM subscription key. It is sent as the
# `api-key` header (what the gateway APIs expect), not just as a Bearer token.
# Get it with: terraform -chdir=../02-apim output -raw subscription_key

# --- LLM (OpenAI-compatible, via the APIM gateway) ---
# e.g. https://<apim>.azure-api.net/gpt-oss
LLM_BASE_URL=
LLM_MODEL=qwen3:1.7b
LLM_API_KEY=

# --- Embeddings (OpenAI-compatible, via the APIM gateway) ---
# e.g. https://<apim>.azure-api.net/embeddings
EMBED_BASE_URL=
EMBED_MODEL=qwen3-embedding:0.6b
EMBED_API_KEY=

# --- Knowledge store (Azure AI Search) ---
# From: terraform -chdir=../00-infra output -raw search_endpoint / search_api_key
SEARCH_ENDPOINT=https://<search-name>.search.windows.net
SEARCH_INDEX=knowledge
SEARCH_API_KEY=
TOP_K=4
